<Window x:Class="DS4WinWPF.DS4Forms.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DS4Windows - Login" Height="480" Width="450"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow" ShowInTaskbar="True">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock Grid.Row="0" Text="DS4Windows Login" FontSize="18" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,20,0,25"/>
        
        <StackPanel Grid.Row="1" Margin="50,10,50,10" VerticalAlignment="Top">
            <TextBlock Text="Usuario:" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <TextBox x:Name="UsernameTextBox" Height="32" Margin="0,0,0,20" FontSize="14" VerticalContentAlignment="Center"/>
            
            <TextBlock Text="Contraseña:" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <PasswordBox x:Name="PasswordBox" Height="32" Margin="0,0,0,20" FontSize="14" VerticalContentAlignment="Center"/>
            
            <TextBlock Text="Token (opcional):" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <TextBox x:Name="TokenTextBox" Height="32" Margin="0,0,0,20" FontSize="14" VerticalContentAlignment="Center"/>
        </StackPanel>
        
        <TextBlock Grid.Row="2" x:Name="StatusLabel" Text="" Foreground="Red" FontSize="11"
                   HorizontalAlignment="Center" Margin="20,10,20,15" TextWrapping="Wrap"/>
        
        <StackPanel Grid.Row="3" HorizontalAlignment="Center" Margin="0,0,0,25">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                <Button x:Name="LoginButton" Content="Iniciar Sesión" Width="110" Height="35" 
                        Margin="0,0,15,0" Click="LoginButton_Click" FontSize="12"/>
                <Button x:Name="CancelButton" Content="Cancelar" Width="110" Height="35" 
                        Click="CancelButton_Click" FontSize="12"/>
            </StackPanel>
            <TextBlock x:Name="VersionLabel" Text="" FontSize="10" Foreground="Gray" 
                       HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>